# Protocol Counsel - Environment Variables
# Copy this file to .env.local and fill in your values

# =====================================================
# STRIPE CONFIGURATION
# =====================================================

# Stripe API Keys (from Stripe Dashboard > Developers > API keys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Brand Segmentation (set in Stripe Dashboard > Settings > Business)
# STATEMENT: PROTOCOL COUNSEL (max 22 chars)
# SHORTENED: PCLAW
STRIPE_STATEMENT_DESCRIPTOR=PROTOCOL COUNSEL
STRIPE_SHORTENED_DESCRIPTOR=PCLAW

# Public Business Profile
STRIPE_SUPPORT_EMAIL=support@protocolcounsel.com
STRIPE_SUPPORT_PHONE=+18007768329
STRIPE_SUPPORT_ADDRESS=123 Legal Plaza Suite 400 Henderson NV 89011

# Stripe Connect (for partner revenue split)
STRIPE_CONNECT_ENABLED=true
STRIPE_PLATFORM_FEE_PERCENT=15

# =====================================================
# SUPABASE / DATABASE
# =====================================================

# Supabase Connection (from Supabase Dashboard > Settings > Database)
DATABASE_URL=postgres://postgres:[password]@db.[project].supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://[project].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =====================================================
# TWILIO / SMS & VOICE
# =====================================================

# Twilio Credentials (from Twilio Console)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+18007768329

# Scheduling Window (8 AM - 8 PM local time)
SCHEDULING_START_HOUR=8
SCHEDULING_END_HOUR=20

# =====================================================
# SLA CONFIGURATION - SAME-DAY PRIORITY
# =====================================================

# 12:00 PM EST cut-off for same-day priority service
# Set in Stripe Dashboard: See SLA rules
SLA_SAME_DAY_CUTOFF_HOUR=12
SLA_SAME_DAY_TIMEZONE=America/New_York
SLA_ENABLED=true

# Quiet Hours (no automated outreach)
QUIET_HOURS_START=20  # 8 PM
QUIET_HOURS_END=8    # 8 AM

# =====================================================
# GPS & PROOF OF VISIT
# =====================================================

GPS_FENCE_RADIUS=100  # meters
PROOF_OF_VISIT_REQUIRED=true
PHOTO_UPLOAD_MAX_SIZE_MB=10

# =====================================================
# SECURITY & AUTHENTICATION
# =====================================================

# NextAuth (generate: openssl rand -base64 32)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=...

# WebAuthn / Passkey
WEBAUTHN_ENABLED=true

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# =====================================================
# INTEGRATIONS (OPTIONAL)
# =====================================================

# OpenAI (for message mediation)
OPENAI_API_KEY=sk-...

# Linear (for IT support tickets)
LINEAR_API_KEY=lin...

# Vercel Deployment Protection Bypass
VERCEL_PROTECTION_BYPASS_SECRET=...

# =====================================================
# FEATURE FLAGS
# =====================================================

FEATURE_WEBHOOKS_ENABLED=true
FEATURE_EXTERNAL_API_ENABLED=true
FEATURE_PORTAL_EMBED_ENABLED=true
FEATURE_IT_SUPPORT_ENABLED=true
FEATURE_CREDIBILITY_SCOUT_ENABLED=true

# Compliance
COMPLIANCE_SB53_ENABLED=true
COMPLIANCE_CO_AI_ACT_ENABLED=true
COMPLIANCE_NON_TRAINING_GUARANTEE=true