// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// LEGAL OPERATIONS SAAS PLATFORM SCHEMA
// ===========================================

// Product catalog
model Product {
  id          String   @id @default(cuid())
  stripeId    String?  @unique
  productId  String   @unique // e.g., "prod_starter"
  slug       String   @unique // e.g., "protocol-counsel-starter"
  name       String
  description String?
  complianceLevel ComplianceLevel @default(STANDARD)
  
  prices     Price[]
  orders    Order[]
  subscriptions Subscription[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ComplianceLevel {
  STANDARD
  PREMIUM
  ENTERPRISE
}

// Pricing tiers
model Price {
  id          String   @id @default(cuid())
  stripeId    String?  @unique
  product    Product  @relation(fields: [productId], references: [id])
  productId  String
  
  tierId     String   // e.g., "monthly", "annual", "custom"
  name      String
  amount    Int      // in cents
  interval  String   // "month" or "year"
  active    Boolean  @default(true)
  custom    Boolean  @default(false)
  
  subscriptions SubscriptionPrice[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, tierId])
}

// ===========================================
// CONTRACT SYSTEM (Subscription Contracts)
// ===========================================
model Contract {
  id                  String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id])
  
  contractTerm        Int      // 12, 24, or 36 months
  status              ContractStatus @default(PENDING)
  
  monthlyPrice        Int      // Price per month in dollars (whole dollars)
  stripeSubscriptionId String?
  stripeCustomerId   String?
  
  startDate          DateTime?
  endDate           DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, id])
}

enum ContractStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

// ===========================================
// BILLING - Order Billing
// ===========================================
model Order {
  id                  String   @id @default(cuid())
  stripeSessionId     String?  @unique
  stripePaymentIntentId String?
  stripeCustomerId    String?
  
  user                User    @relation(fields: [userId], references: [id])
  userId              String
  
  product             Product @relation(fields: [productId], references: [id])
  productId           String
  
  // Blind case ID (anonymized for field agents)
  anonymizedCaseId   String?  @unique // e.g., "CASE-2024-XK792"
  
  // Order details
  orderNumber        String   @unique // e.g., "ORD-2024-0001"
  taskDescription  String?  // Task description for agent view
  serviceType       String   // e.g., "incorporation", "contract-review"
  servicePrice     Int      // in dollars (whole dollars only)
  processingFee    Float    @default(9.99)
  amountTotal     Int      // servicePrice + processingFee in cents
  
  // Shipping
  shippingLabelUrl  String?
  shippingTechFee Float    @default(4.00)
  shippedAt       DateTime?
  
  // Billing
  billingType      BillingType @default(IMMEDIATE) // IMMEDIATE or NET_15 or NET_30
  netTermsStatus  NetTermsStatus? // only for NET_* 
  paymentStatus   PaymentStatus @default(PENDING)
  
  // Agent payout
  agentPayoutAmount Int?    // Payout to field agent (cents)
  agentPayoutId   String?
  
  // Status
  status           OrderStatus @default(NEW)
  
  // Field agent assignment
  fieldAgentId    String?
  fieldAgent     FieldAgent? @relation(fields: [fieldAgentId], references: [id])
  
  // Document bundle
  documents      Document[]
  documentStatus DocumentStatus @default(PENDING)
  
  // Timeline
  timeline       OrderTimeline[]
  
  // Messages (notes go through scrub relay)
  messages        Message[]
  
  metadata        Json?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BillingType {
  IMMEDIATE
  NET_15
  NET_30
}

enum NetTermsStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum OrderStatus {
  NEW
  PROCESSING
  SCHEDULED
  COMPLETED
  ARCHIVED
}

enum DocumentStatus {
  PENDING
  UPLOADED
  SIGNED
  COMPLETED
}

// ===========================================
// ORDER TIMELINE
// ===========================================
model OrderTimeline {
  id          String   @id @default(cuid())
  order       Order    @relation(fields: [orderId], references: [id])
  orderId     String
  
  status     String   // NEW, PROCESSING, SCHEDULED, COMPLETED
  note       String?
  userId     String?  // who made the change
  userName   String?  // cached user name
  
  createdAt  DateTime @default(now())
}

// ===========================================
// DOCUMENTS
// ===========================================
model Document {
  id          String   @id @default(cuid())
  order       Order    @relation(fields: [orderId], references: [id])
  orderId     String
  
  name       String   // Original filename
  storedName String   // Encrypted storage name
  type       DocumentType
  version    Int      @default(1)
  status     String   @default(PENDING)
  
  // Encryption
  encryptionKey String? // Encrypted per-document key
  checksum     String? // SHA256 for integrity
  
  uploadedBy String?
  uploadedAt DateTime @default(now())
  
  // Signed document URL (for signed docs)
  signedUrl  String?
  signedAt   DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DocumentType {
  UPLOAD
  TEMPLATE
  SIGNED
  OTHER
}

// ===========================================
// USER / LAW FIRM
// ===========================================
model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  businessName       String
  lawFirmType        LawFirmType
  
  // Account status
  status             UserStatus @default(ACTIVE)
  
  // Signup data
  bankAccountToken   String?  // Tokenized bank account
  creditCardToken   String?  // Tokenized credit card
  fedExAccount      String?
  upsAccount        String?
  dhlAccount       String?
  
  // Shipping preferences
  shippingPreference ShippingPreference?
  defaultReturnAddress String?
  dhsShipping       Boolean  @default(false)
  complianceShipping Boolean @default(false)
  
  // Billing contact
  billingContact    String?
  billingEmail     String?
  
  // Contracts
  contracts         Contract[]
  orders            Order[]
  
  // Portal sessions
  sessions          Session[]
  
  // Messages sent by user
  userMessages     Message[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LawFirmType {
  SOLE_PRACTITIONER
  SMALL_FIRM        // 2-10 attorneys
  MEDIUM_FIRM      // 11-50 attorneys
  LARGE_FIRM       // 50+ attorneys
  IN_HOUSE        // In-house counsel
}

enum UserStatus {
  PENDING     // Awaiting email verification
  ACTIVE      // Full access
  NET_PENDING // Net terms application pending
  SUSPENDED   // Temporarily disabled
  BANNED     // Permanently disabled
}

enum ShippingPreference {
  FEDEX
  UPS
  USPS
  OTHER
}

// ===========================================
// PORTAL SESSIONS
// ===========================================
model Session {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  
  token      String   @unique
  expiresAt  DateTime
  
  createdAt  DateTime @default(now())
}

// ===========================================
// FIELD AGENTS
// ===========================================
model FieldAgent {
  id          String   @id @default(cuid())
  email       String   @unique
  name       String
  phone      String?
  status     AgentStatus @default(ACTIVE)
  
  // Payout ledger
  payouts     Payout[]
  orders     Order[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AgentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ===========================================
// AGENT PAYOUT LEDGER
// ===========================================
model Payout {
  id           String   @id @default(cuid())
  fieldAgent   FieldAgent @relation(fields: [fieldAgentId], references: [id])
  fieldAgentId String
  
  orderId    String?  // Associated order
  amount    Int      // in cents
  status    PayoutStatus @default(PENDING)
  
  // Stripe payout reference
  stripePayoutId String?
  
  createdAt DateTime @default(now())
  paidAt   DateTime?
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

// ===========================================
// AI MESSAGING SYSTEM
// ===========================================
model Message {
  id          String   @id @default(cuid())
  order       Order   @relation(fields: [orderId], references: [id])
  orderId    String
  
  sender     MessageSender
  user       User?    @relation(fields: [userId], references: [id])
  userId     String?
  
  // Note relay - scrub agent names for client portal
  isAgentNote Boolean @default(false)
  scrubbedContent String? // Agent content with name removed
  
  deliveryMethod MessageDelivery
  
  content    String
  metadata  Json?    // For AI: appointment suggestions, etc.
  
  readAt    DateTime?
  sentAt   DateTime @default(now())
}

enum MessageSender {
  USER
  SYSTEM
  AI
}

enum MessageDelivery {
  IN_APP
  EMAIL
  SMS
}

// ===========================================
// SUBSCRIPTIONS (Stripe-backed)
// ===========================================
model Subscription {
  id                String   @id @default(cuid())
  stripeSubscriptionId String  @unique
  stripeCustomerId   String?
  
  product           Product  @relation(fields: [productId], references: [id])
  productId        String
  
  price            Price   @relation(fields: [priceId], references: [id])
  priceId         String
  
  status            SubscriptionStatus
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean  @default(false)
  
  metadata         Json?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  UNPAID
}

// Subscription price
model SubscriptionPrice {
  id          String   @id @default(cuid())
  subscription Subscription @relation(fields: [subscriptionId], references: [id])
  subscriptionId String
  
  price       Price    @relation(fields: [priceId], references: [id])
  priceId     String
  
  createdAt   DateTime @default(now())
}

// Customer
model Customer {
  id              String   @id @default(cuid())
  stripeCustomerId String  @unique
  email         String   @unique
  
  subscriptions  Subscription[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
